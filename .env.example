# ============================================================================
# Sports Betting Analytics — environment template
# ----------------------------------------------------------------------------
# Copy this file to `.env` (repo root) for the API + worker services.
# The Next.js web app reads its own values from `web-app/.env.local`
# (or, in compose, the same `.env` via the `env_file:` directive).
#
# Anything marked REQUIRED must be set before first launch.
# Everything else has a sane default and is safe to leave commented out.
# ============================================================================


# ----------------------------------------------------------------------------
# Public hostnames (used by Caddy, CORS, and the Next.js client)
# ----------------------------------------------------------------------------
# REQUIRED in production. Used to:
#   - issue Let's Encrypt certs in the proxy
#   - lock down API CORS
#   - generate absolute URLs in the web app
APP_DOMAIN=app.example.com
API_DOMAIN=api.example.com

# Email Caddy registers with Let's Encrypt for cert lifecycle notices.
# REQUIRED in production. Use a real inbox you monitor.
ACME_EMAIL=ops@example.com


# ----------------------------------------------------------------------------
# API service — FastAPI / uvicorn
# ----------------------------------------------------------------------------
# Comma-separated list of allowed CORS origins. Wildcard (*) is rejected.
# REQUIRED if APP_DOMAIN differs from defaults below.
API_CORS_ORIGINS=https://app.example.com

# Path inside the API container. Must point at the persistent volume
# mounted at /app/data. Worker writes here; API reads.
SPORTS_DB_PATH=/app/data/betting.db

# Path inside the API container for serialized model artifacts.
MODELS_DIR=/app/models

# Comma-separated list of leagues released to end users. The API uses this
# to mask predictions for leagues that haven't passed validation.
RELEASE_LEAGUES=NBA,NHL,EPL,LALIGA,BUNDESLIGA,SERIEA,LIGUE1

# Freshness gates for the /health and /ready endpoints (minutes).
ODDS_FRESHNESS_MINUTES=180
PREDICTIONS_FRESHNESS_MINUTES=1440

# Free-disk threshold (MB) below which /ready reports unhealthy.
MIN_DISK_FREE_MB=512


# ----------------------------------------------------------------------------
# Auth — Clerk
# ----------------------------------------------------------------------------
# REQUIRED. Server-side secret. Used by FastAPI to validate session JWTs and
# by Next.js for server actions / route handlers.
CLERK_SECRET_KEY=sk_live_replace_me

# REQUIRED. Frontend-safe key, also embedded in Next.js bundle.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_live_replace_me

# Optional. Pin issuer/JWKS for offline JWT validation. If unset, the API
# falls back to remote verification via CLERK_API_URL.
# CLERK_FRONTEND_API_URL=https://clerk.example.com
# CLERK_ISSUER=https://clerk.example.com
# CLERK_JWKS_URL=https://clerk.example.com/.well-known/jwks.json
# CLERK_JWT_KEY=

# Optional tunables.
CLERK_API_URL=https://api.clerk.com
CLERK_REQUEST_TIMEOUT_SECONDS=3.0
CLERK_CACHE_TTL_SECONDS=60
CLERK_JWT_CLOCK_SKEW_SECONDS=60
# CLERK_AUTHORIZED_PARTIES=https://app.example.com

# Sign-in / sign-up routes (Next.js).
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/login
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/signup


# ----------------------------------------------------------------------------
# Web app — Next.js
# ----------------------------------------------------------------------------
# REQUIRED. Used by the web app to call the API (server-side and client-side).
NEXT_PUBLIC_API_URL=https://api.example.com
NEXT_PUBLIC_APP_URL=https://app.example.com


# ----------------------------------------------------------------------------
# Billing — Stripe (optional for first launch, required for paid tiers)
# ----------------------------------------------------------------------------
STRIPE_SECRET_KEY=sk_live_replace_me
STRIPE_WEBHOOK_SECRET=whsec_replace_me
STRIPE_PRICE_ID=price_live_replace_me


# ----------------------------------------------------------------------------
# Data sources — odds & scores
# ----------------------------------------------------------------------------
# REQUIRED for ingest. Add as many keys as you have; the manager rotates
# through them. Indices must be contiguous starting at _2.
ODDS_API_KEY=replace_me
# ODDS_API_KEY_2=
# ODDS_API_KEY_3=
# ODDS_API_KEY_4=

ODDS_API_REGION=us
# ODDS_API_MARKET=h2h
# ODDS_API_SPORT=americanfootball_nfl
# ODDS_API_BASE_URL=https://api.the-odds-api.com/v4
ODDS_API_MIN_FETCH_MINUTES=30

# Optional secondary sources.
# FOOTBALL_DATA_API_KEY=
# ODDSPAPI_API_KEY=
# CFBD_API_KEY=
# KILLERSPORTS_USERNAME=
# KILLERSPORTS_PASSWORD=


# ----------------------------------------------------------------------------
# Worker — pipeline schedule
# ----------------------------------------------------------------------------
# Cron expressions consumed by scripts/worker_entrypoint.sh.
# Times are UTC inside the worker container.

# Hourly fast pipeline: ingest + predict, no retraining.
WORKER_PREDICT_CRON=15 * * * *

# Daily training pipeline: full ingest + train + predict.
WORKER_TRAIN_CRON=0 9 * * *

# Daily local backup snapshot.
WORKER_BACKUP_CRON=0 18 * * *

# Daily external backup push (after WORKER_BACKUP_CRON).
WORKER_REMOTE_BACKUP_CRON=30 18 * * *


# ----------------------------------------------------------------------------
# Backup — local retention
# ----------------------------------------------------------------------------
# Local backup dir (inside worker container; mounted to host volume).
BACKUP_DIR=/app/backups
# Number of daily snapshot directories to retain on the local disk.
LOCAL_BACKUP_RETENTION_DAYS=7


# ----------------------------------------------------------------------------
# Backup — external object storage (S3-compatible)
# ----------------------------------------------------------------------------
# REQUIRED before going live. Tested with AWS S3, Backblaze B2, Cloudflare R2,
# and any S3-compatible endpoint that aws-cli understands.
BACKUP_S3_BUCKET=sports-betting-backups
BACKUP_S3_PREFIX=prod
# Leave blank for AWS S3; set for B2/R2/MinIO/etc.
# BACKUP_S3_ENDPOINT=https://s3.us-west-002.backblazeb2.com
# BACKUP_S3_REGION=us-east-1

# Credentials for the backup bucket. Use a dedicated IAM user/key with
# write+list+get on the bucket only. Never reuse human credentials.
AWS_ACCESS_KEY_ID=replace_me
AWS_SECRET_ACCESS_KEY=replace_me

# Object lifecycle. Configure on the bucket itself (preferred) or rely on
# the restore-drill to verify retention is honored.
REMOTE_BACKUP_RETENTION_DAYS=30


# ----------------------------------------------------------------------------
# Logging
# ----------------------------------------------------------------------------
LOG_LEVEL=INFO
